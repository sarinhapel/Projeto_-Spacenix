function selecionarChip(chip) {
  const allChips = chip.closest(".card-chips").querySelectorAll(".chip");
  allChips.forEach(c => c.classList.remove("selected"));
  chip.classList.add("selected");

  const label = chip.dataset.label;
  const preco = chip.dataset.preco;

  const body = chip.closest(".card-body");
  body.querySelector(".card-selected-label").textContent = "Cor: " + label;
  body.querySelector(".card-price").textContent = preco;
}

function comprarWhatsApp(btn, nome, cat, arm) {
  const card = btn.closest(".card");
  const chipSel = card.querySelector(".chip.selected");
  const cor = chipSel ? chipSel.dataset.label : "—";
  const preco = card.querySelector(".card-price").textContent;

  const msg = encodeURIComponent(
    `Olá, Spacenix! 👋\n\nTenho interesse no seguinte produto:\n\n📱 *${nome}*\n📦 Categoria: ${cat}\n💾 Armazenamento: ${arm}\n🎨 Cor/Variante: ${cor}\n💰 Preço: ${preco}\n\nPoderia me dar mais informações?`
  );

  window.open(`https://wa.me/${WA}?text=${msg}`, "_blank");
}

function abrirLightbox(emoji, badge, badgeClass, nome, cat, preco) {
  document.getElementById("lightboxImg").textContent = emoji;
  document.getElementById("lbBadge").textContent = badge;
  document.getElementById("lbBadge").className = `card-badge lb-badge ${badgeClass}`;
  document.getElementById("lbName").textContent = nome;
  document.getElementById("lbCat").textContent = cat;
  document.getElementById("lbPrice").textContent = preco;
  document.getElementById("lightboxOverlay").classList.add("open");
}

// ===================== RENDER =====================
function renderAll() {
  Object.keys(produtos).forEach(secao => {
    const grid = document.getElementById(`grid-${secao}`);
    if (!grid) return;
    produtos[secao].forEach(p => {
      grid.appendChild(criarCard(p, secao));
    });
  });
}

// ===================== LIGHTBOX =====================
document.getElementById("lightboxClose").addEventListener("click", () => {
  document.getElementById("lightboxOverlay").classList.remove("open");
});
document.getElementById("lightboxOverlay").addEventListener("click", (e) => {
  if (e.target === document.getElementById("lightboxOverlay")) {
    document.getElementById("lightboxOverlay").classList.remove("open");
  }
});
document.addEventListener("keydown", (e) => {
  if (e.key === "Escape") document.getElementById("lightboxOverlay").classList.remove("open");
});

// ===================== TABS =====================
document.querySelectorAll(".tab-btn").forEach(btn => {
  btn.addEventListener("click", () => {
    document.querySelectorAll(".tab-btn").forEach(b => b.classList.remove("active"));
    btn.classList.add("active");
    const target = document.getElementById(btn.dataset.target);
    if (target) {
      const offset = 64 + 52; // nav + tabs
      const top = target.getBoundingClientRect().top + window.scrollY - offset;
      window.scrollTo({ top, behavior: "smooth" });
    }
  });
});

// ===================== SCROLL → ATUALIZA TAB ATIVA =====================
const sections = ["iphones-novos", "spacenix-phones", "xiaomi", "tablets", "watches", "acessorios"];
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      const id = entry.target.id;
      document.querySelectorAll(".tab-btn").forEach(btn => {
        btn.classList.toggle("active", btn.dataset.target === id);
      });
    }
  });
}, { rootMargin: "-120px 0px -60% 0px" });

sections.forEach(id => {
  const el = document.getElementById(id);
  if (el) observer.observe(el);
});

// ===================== SMOOTH SCROLL (botões hero) =====================
document.querySelectorAll(".scroll-link").forEach(link => {
  link.addEventListener("click", (e) => {
    const href = link.getAttribute("href");
    if (href.startsWith("#")) {
      e.preventDefault();
      const target = document.querySelector(href);
      if (target) {
        const offset = 64 + 52;
        const top = target.getBoundingClientRect().top + window.scrollY - offset;
        window.scrollTo({ top, behavior: "smooth" });
      }
    }
  });
});

// ===================== MOBILE MENU =====================
document.getElementById("navToggle").addEventListener("click", () => {
  document.getElementById("navLinks").classList.toggle("open");
});

document.querySelectorAll(".nav-links a").forEach(link => {
  link.addEventListener("click", () => {
    document.getElementById("navLinks").classList.remove("open");
  });
});

// ===================== NAV SCROLL =====================
window.addEventListener("scroll", () => {
  const nav = document.getElementById("nav");
  nav.style.background = window.scrollY > 40
    ? "rgba(2,5,16,0.97)"
    : "rgba(2,5,16,0.85)";
});

