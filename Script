// ===================== CRIAR CARDS =====================
function criarCard(produto, secaoId) {
  const card = document.createElement("div");
  card.className = "card";

  // Preço inicial (primeira variante)
  const precoInicial = produto.variantes[0].preco;

  // Chips de variantes
  const chipsHTML = produto.variantes.map((v, i) =>
    `<button class="chip${i === 0 ? ' selected' : ''}" data-label="${v.label}" data-preco="${v.preco}" onclick="selecionarChip(this)">${v.label}</button>`
  ).join("");

  const labelInicial = produto.variantes[0].label;
  const garantiaHTML = produto.garantia
    ? `<div class="card-guarantee">${produto.garantia}</div>`
    : "";

  card.innerHTML = `
    <div class="card-photo" onclick="abrirLightbox('${produto.emoji}', '${produto.badge}', '${produto.badgeClass}', \`${produto.nome}\`, \`${produto.cat} · ${produto.armazenamento}\`, '${precoInicial}')">
      <div>
        <div class="card-photo-emoji">${produto.emoji}</div>
        <div class="card-photo-text">Ver foto</div>
      </div>
    </div>
    <div class="card-body">
      <span class="card-badge ${produto.badgeClass}">${produto.badge}</span>
      <div class="card-name">${produto.nome}</div>
      <div class="card-cat">${produto.cat} · ${produto.armazenamento}</div>
      <div class="card-chips">${chipsHTML}</div>
      <div class="card-selected-label" id="lbl-selected">Cor: ${labelInicial}</div>
      <div class="card-price">${precoInicial}</div>
    </div>
    <div class="card-footer">
      <button class="btn-whatsapp" onclick="comprarWhatsApp(this, '${produto.nome}', '${produto.cat}', '${produto.armazenamento}')">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.558 4.116 1.532 5.85L0 24l6.335-1.524A11.953 11.953 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.885 0-3.647-.488-5.178-1.342l-.371-.214-3.763.905.952-3.659-.234-.381A9.934 9.934 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
        Comprar
