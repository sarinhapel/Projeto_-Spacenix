</head>
<body>

<!-- ===================== NAV ===================== -->
<nav class="nav" id="nav">
  <div class="nav-inner">
    <a href="#" class="nav-logo">
      <div class="mascot-icon">
        <svg viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="30" cy="30" r="30" fill="url(#logoGrad)"/>
          <text x="30" y="38" text-anchor="middle" font-size="28" fill="white">🦌</text>
          <defs>
            <linearGradient id="logoGrad" x1="0" y1="0" x2="60" y2="60">
              <stop offset="0%" stop-color="#00c8ff"/>
              <stop offset="100%" stop-color="#0055ff"/>
            </linearGradient>
          </defs>
        </svg>
      </div>
      <span class="nav-brand">SPACENIX</span>
    </a>
    <button class="nav-toggle" id="navToggle" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
    <div class="nav-links" id="navLinks">
      <a href="#iphones-novos">iPhones Novos</a>
      <a href="#spacenix-phones">Spacenix Phones</a>
      <a href="#xiaomi">Xiaomi</a>
      <a href="#tablets">Tablets</a>
      <a href="#watches">Watches</a>
      <a href="#acessorios">Acessórios</a>
