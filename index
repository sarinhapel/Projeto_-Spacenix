    <button class="btn-entrar">Entrar</button>
  </div>
</nav>

<!-- ===================== HERO ===================== -->
<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-content">
    <p class="hero-tag">✦ Eletrônicos com procedência garantida</p>
    <h1 class="hero-title">Eletrônicos originais<br/><span>com garantia.</span></h1>
    <p class="hero-sub">Produtos lacrados, revisados e com garantia real. Aqui você encontra iPhones novos, Spacenix Phones certificados, Xiaomi, tablets, watches e acessórios — tudo com suporte especializado.</p>
    <div class="hero-btns">
      <a href="#iphones-novos" class="btn-primary scroll-link">Ver iPhones</a>
      <a href="#spacenix-phones" class="btn-secondary scroll-link">Spacenix Phones</a>
    </div>
    <div class="hero-badges">
      <span>📦 Produtos Lacrados</span>
      <span>🍎 Garantia Apple</span>
      <span>🔒 Compra Segura</span>
      <span>💬 Atend. Especializado</span>
    </div>
  </div>
  <div class="hero-orb hero-orb1"></div>
  <div class="hero-orb hero-orb2"></div>
</section>

<!-- ===================== MARQUEE ===================== -->
<div class="marquee-wrap">
  <div class="marquee-track">
    <span>📍 São Paulo, SP</span>
    <span>📦 Produtos Lacrados & Originais</span>
    <span>🍎 Garantia Apple Válida</span>
    <span>💬 Atendimento via WhatsApp</span>
    <span>🔒 Compra 100% Segura</span>
    <span>🚀 Spacenix — Sua loja de confiança</span>
    <span>⭐ Spacenix Phones com até 1 ano de garantia</span>
    <span>📱 Parcele em até 12x</span>
    <span>📍 São Paulo, SP</span>
    <span>📦 Produtos Lacrados & Originais</span>
    <span>🍎 Garantia Apple Válida</span>
    <span>💬 Atendimento via WhatsApp</span>
    <span>🔒 Compra 100% Segura</span>
    <span>🚀 Spacenix — Sua loja de confiança</span>
    <span>⭐ Spacenix Phones com até 1 ano de garantia</span>
    <span>📱 Parcele em até 12x</span>
  </div>
</div>

<!-- ===================== TABS ===================== -->
<div class="tabs-wrap" id="tabsWrap">
  <div class="tabs">
    <button class="tab-btn active" data-target="iphones-novos">iPhones Novos</button>
    <button class="tab-btn" data-target="spacenix-phones">Spacenix Phones</button>
    <button class="tab-btn" data-target="xiaomi">Xiaomi</button>
    <button class="tab-btn" data-target="tablets">Tablets</button>
    <button class="tab-btn" data-target="watches">Watches</button>
    <button class="tab-btn" data-target="acessorios">Acessórios</button>
  </div>
</div>

<!-- ===================== SEÇÕES ===================== -->
<main class="main-content">

  <!-- iPhones Novos -->
  <section class="section" id="iphones-novos">
    <div class="section-header">
      <h2>iPhones Novos <span>Lacrados</span></h2>
      <p>100% originais, lacrados de fábrica, com garantia Apple válida</p>
    </div>
    <div class="cards-grid" id="grid-iphones-novos"></div>
  </section>

  <!-- Spacenix Phones -->
  <section class="section" id="spacenix-phones">
    <div class="section-header">
      <h2>Spacenix Phones <span>Usados</span></h2>
      <p>Revisados e com garantia Spacenix — 6 meses a 1 ano conforme o modelo</p>
    </div>
    <div class="cards-grid" id="grid-spacenix-phones"></div>
  </section>

  <!-- Xiaomi -->
  <section class="section" id="xiaomi">
    <div class="section-header">
      <h2>Xiaomi / Redmi / Poco</h2>
      <p>Versões globais lacradas. <strong>Sem garantia de fábrica no Brasil</strong> — suporte via Spacenix.</p>
    </div>
    <div class="notice-box">⚠️ Estes aparelhos são versões globais importadas. Não possuem garantia de fábrica no Brasil. O suporte é prestado diretamente pela Spacenix.</div>
    <div class="cards-grid" id="grid-xiaomi"></div>
  </section>

  <!-- Tablets -->
  <section class="section" id="tablets">
    <div class="section-header">
      <h2>Tablets</h2>
      <p>iPads originais e Xiaomi Pad — novos e lacrados</p>
    </div>
    <div class="cards-grid" id="grid-tablets"></div>
  </section>

  <!-- Watches -->
  <section class="section" id="watches">
    <div class="section-header">
      <h2>Apple Watch</h2>
      <p>Originais, lacrados, com garantia Apple</p>
    </div>
    <div class="cards-grid" id="grid-watches"></div>
  </section>

  <!-- Acessórios -->
  <section class="section" id="acessorios">
    <div class="section-header">
      <h2>Acessórios Apple</h2>
      <p>AirTags, AirPods, Apple Pencil, Magic Mouse e mais</p>
    </div>
    <div class="cards-grid" id="grid-acessorios"></div>
  </section>

</main>

<!-- ===================== MARCAS ===================== -->
<section class="brands-section">
  <div class="brands-inner">
    <span class="brand-tag">🍎 Apple</span>
    <span class="brand-tag">Xiaomi</span>
    <span class="brand-tag">Redmi</span>
    <span class="brand-tag">Poco</span>
    <span class="brand-tag">Realme</span>
    <span class="brand-tag">Infinix</span>
  </div>
</section>

<!-- ===================== DIFERENCIAIS ===================== -->
<section class="features-section">
  <div class="features-grid">
    <div class="feature-card">
      <div class="feat-icon">📦</div>
      <h3>Produtos Lacrados</h3>
      <p>Direto da fábrica, sem violação de qualquer tipo</p>
    </div>
