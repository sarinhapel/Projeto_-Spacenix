      <div class="feat-icon">🍎</div>
      <h3>Garantia Apple</h3>
      <p>iPhones novos com garantia oficial da Apple ativa</p>
    </div>
    <div class="feature-card">
      <div class="feat-icon">⭐</div>
      <h3>Spacenix Phones</h3>
      <p>Usados revisados com até 1 ano de garantia da loja</p>
    </div>
    <div class="feature-card">
      <div class="feat-icon">💳</div>
      <h3>Parcele em 12x</h3>
      <p>Condições especiais de parcelamento para você</p>
    </div>
  </div>
</section>

<!-- ===================== NEWSLETTER ===================== -->
